local function openTileTimesFile()
    local d = os.date("*t")
    tileTimesFile = string.format("%s/tileTimes_%04d-%02d-%02d_%02dh.csv",
        sessionFolder, d.year, d.month, d.day, d.hour)
    if not isfile(tileTimesFile) then
        writefile(tileTimesFile, "Timestamp,AssetID,AssetName,TimeRemaining\n")
    end
end

local function parseTimeString(txt)
    return txt:match("%d+:%d+:%d+") or txt:match("%d+:%d+") or txt:match("%d+s") or nil
end

task.spawn(function()
    while _G.Running do
        task.wait(1)
        if not isFarming then continue end
        local sg2         = getScreenGui()
        local grid        = sg2 and sg2:FindFirstChild("TileGrid")
        local mouseoverBox = sg2 and sg2:FindFirstChild("MouseoverBox")
        if not grid or not mouseoverBox then continue end
        if tileTimesFile == "" and sessionFolder ~= "" then openTileTimesFile() end
        if tileTimesFile == "" then continue end

        local nowStr = os.date("%Y-%m-%d %H:%M:%S")

        for _, tile in ipairs(grid:GetChildren()) do
            if tile.Name ~= "IconTile" then continue end
            local bg = tile:FindFirstChild("BG")
            if not bg then continue end
            local iconLbl = bg:FindFirstChild("Icon")
            if not iconLbl then continue end
            local assetId = (iconLbl.Image or ""):match("%d+")
            if not assetId then continue end

            local ok = pcall(function()
                for _, conn in pairs(getconnections(tile.MouseEnter)) do conn:Fire() end
            end)
            if not ok then continue end
            RunService.Heartbeat:Wait()

            local timeStr = parseTimeString(mouseoverBox.Text or "")
            pcall(function()
                for _, conn in pairs(getconnections(tile.MouseLeave)) do conn:Fire() end
            end)
            if not timeStr then continue end

            local name     = getAssetName(assetId)
            local safeName = '"'..name:gsub('"', '""')..'"'
            table.insert(tileTimesBuffer, string.format(
                "%s,%s,%s,%s", nowStr, assetId, safeName, timeStr
            ))
            task.wait(0.05)
        end

        if #tileTimesBuffer > 0 then
            appendfile(tileTimesFile, table.concat(tileTimesBuffer, "\n").."\n")
            tileTimesBuffer = {}
        end
    end
end)

