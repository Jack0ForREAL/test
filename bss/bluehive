-- ── Balloon pollen reader (cached) ──────────────────────────
local BALLOON_SEARCH_RADIUS = 30

local function findNearestBalloon(hPos)
    local best, bestDist = nil, BALLOON_SEARCH_RADIUS
    local okD, desc = pcall(function() return workspace:GetDescendants() end)
    if not okD or not desc then return nil end
    for _, obj in ipairs(desc) do
        if obj and obj.Parent and obj.Name == "BalloonBody" and obj:IsA("BasePart") then
            local okP, d = pcall(function() return (obj.Position - hPos).Magnitude end)
            if okP and d and d < bestDist then bestDist = d; best = obj end
        end
    end
    return best
end

local function readNearestBalloon()
    local hPos = getHivePosOnce()
    if not hPos then return -1 end
    if not cachedBalloonPart or not cachedBalloonPart.Parent then
        cachedBalloonPart = findNearestBalloon(hPos)
    end
    if not cachedBalloonPart or not cachedBalloonPart.Parent then return -1 end
    local okT, val = pcall(function()
        return cachedBalloonPart.GuiAttach.Gui.Bar.TextLabel.Text
    end)
    if not okT or not val or val == "" then
        cachedBalloonPart = nil; return -1
    end
    return tonumber((val:gsub("[,%s]", ""))) or -1
end

local function parseCooldown(txt)
    local h,m,s = txt:match("(%d+):(%d%d):(%d%d)")
    if h then return tonumber(h)*3600 + tonumber(m)*60 + tonumber(s) end
    local m2,s2 = txt:match("(%d+):(%d%d)")
    if m2 then return tonumber(m2)*60 + tonumber(s2) end
    return nil
end

