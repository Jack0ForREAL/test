        for _, tile in ipairs(grid:GetChildren()) do
            if tile.Name ~= "IconTile" then continue end
            local bg = tile:FindFirstChild("BG")
            if not bg then continue end
            local iconLbl = bg:FindFirstChild("Icon")
            if not iconLbl then continue end
            local assetId = (iconLbl.Image or ""):match("%d+")
            if not assetId then continue end

            local ok = pcall(function()
                for _, conn in pairs(getconnections(tile.MouseEnter)) do conn:Fire() end
            end)
            if not ok then continue end
            RunService.Heartbeat:Wait()

            local timeStr = parseTimeString(mouseoverBox.Text or "")
            pcall(function()
                for _, conn in pairs(getconnections(tile.MouseLeave)) do conn:Fire() end
            end)
            if not timeStr then continue end

            local name     = getAssetName(assetId)
            local safeName = '"'..name:gsub('"', '""')..'"'
            table.insert(tileTimesBuffer, string.format(
                "%s,%s,%s,%s", nowStr, assetId, safeName, timeStr
            ))
            task.wait(0.05)
        end

        if #tileTimesBuffer > 0 then
            appendfile(tileTimesFile, table.concat(tileTimesBuffer, "\n").."\n")
            tileTimesBuffer = {}
        end
    end
end)

