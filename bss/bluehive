                    local fb = Fields[pField].bounds
                    local pos = obj.Position
                    if pos.X >= fb.x1 and pos.X <= fb.x2 and pos.Z >= fb.z1 and pos.Z <= fb.z2 then
                        table.insert(planterRewards, obj)
                        local partID = obj.Name
                        local img = obj:FindFirstChildWhichIsA("Decal") or obj:FindFirstChildWhichIsA("SpecialMesh")
                        if img then
                            local tex = tostring(img.Texture or img.MeshId or "")
                            local extracted = tex:match("%d+")
                            if extracted then partID = extracted end
                        end
                        totalPlanterRewards[partID] = (totalPlanterRewards[partID] or 0) + 1
                        if not assetNameCache[partID] then
                            task.spawn(function() getAssetName(partID) end)
                        end
                    end
                end
            end
            local tStart = tick()
            for _, token in ipairs(planterRewards) do
                if tick() - tStart > 15 then break end
                while token and token.Parent and (tick() - tStart <= 15) do
                    local reached = stepToward(hrp, hum, token.Position, 4)
                    if reached then break end
                    task.wait(0.05)
                end
            end
            hum.WalkToPoint = hrp.Position
            tpTo(bulbPos); anchor(); task.wait(1)
            pcall(function() RepStorage.Events.PlayerActivesCommand:FireServer({Name = pName}) end)
            task.wait(3); unanchor(); tpTo(fieldCenter())
            isClaimingPlanter = false
            break
        end
    end
end)

