function renderCapacityPage(s) {{
  const ts     = s.stats.timestamps;
  const shapes = addConvertingShapes(s);
  Plotly.newPlot('capChart',
    [lineTrace(ts, s.stats.capacity, 'Capacity', document.getElementById('col-cap').value, true)],
    {{ ...PLOTLY_LAYOUT_BASE, height: 320, shapes,
       yaxis: {{ ...PLOTLY_LAYOUT_BASE.yaxis, title:'Capacity' }} }},
    PLOTLY_CONFIG);
}}

// ─────────────────────────────────────────────────────────────────────────────
// BALLOON PAGE
// ─────────────────────────────────────────────────────────────────────────────
function renderBalloonPage(log) {{
  const ts      = log.stats.timestamps;
  const raw     = log.stats.balloon_pollen || [];
  const shapes  = addConvertingShapes(log);

  // Replace null/NaN with null so Plotly renders gaps instead of zero
  const balloon = raw.map(v => (v === null || isNaN(v)) ? null : v);

  if (balloon.every(v => v === null)) {{
    document.getElementById('balloonChart').innerHTML =
      '<div class="empty-state" style="padding:40px"><div class="icon">🎈</div>No balloon data in this log.<br>Balloon is only present when converted.</div>';
    return;
  }}

  Plotly.newPlot('balloonChart',
    [{{
      x: ts,
      y: balloon,
      name: 'Balloon Pollen',
      type: 'scatter',
      mode: 'lines',
      line: {{ color: document.getElementById('col-balloon').value, width: 2, shape: 'spline', smoothing: 0.4 }},
      fill: 'tozeroy',
      fillcolor: hexToRgba(document.getElementById('col-balloon').value, 0.07),
      connectgaps: false,
      hovertemplate: '%{{y:,.0f}}<extra>Balloon Pollen</extra>',
    }}],
    {{ ...PLOTLY_LAYOUT_BASE, height: 320, shapes,
       yaxis: {{ ...PLOTLY_LAYOUT_BASE.yaxis, title: 'Pollen Stored' }} }},
    PLOTLY_CONFIG);
}}
// ─────────────────────────────────────────────────────────────────────────────
function renderFieldPage(s) {{
  const fields = s.summary.fields || {{}};
  const total  = Object.values(fields).reduce((a,b) => a+b, 0) || 1;
  const names  = Object.keys(fields);
  const counts = names.map(n => fields[n]);
  const pcts   = counts.map(c => ((c/total)*100).toFixed(1));

  // Bar chart
  Plotly.newPlot('fieldChart', [{{
    x: counts, y: names, type: 'bar', orientation: 'h',
    marker: {{ color: '#f5c542', opacity: 0.85 }},
    hovertemplate: '%{{x}} seconds<extra>%{{y}}</extra>',
  }}], {{
    ...PLOTLY_LAYOUT_BASE, height: Math.max(200, names.length * 36 + 60),
    xaxis: {{ ...PLOTLY_LAYOUT_BASE.xaxis, title: 'Seconds' }},
    margin: {{ t:10, b:50, l:160, r:20 }},
  }}, PLOTLY_CONFIG);

  // Text bars
  const list = document.getElementById('fieldList');
  const maxC = Math.max(...counts, 1);
  list.innerHTML = names.map((n,i) => `
    <div class="field-row">
      <div class="field-name">${{n}}</div>
      <div class="field-bar-bg">
        <div class="field-bar-fill" style="width:${{(counts[i]/maxC*100).toFixed(1)}}%"></div>
      </div>
      <div class="field-pct">${{pcts[i]}}%</div>
    </div>`).join('');
}}

