-- 12.5. PLANTER TASK  — parallel chain executor (robust)
-- ============================================================
--
-- Design:
--   • Each chain runs its own watcher coroutine (identified by chain.id,
--     NOT array index, so delete/add never confuses them).
--   • All actual character movement is serialised through a single
--     "planter action queue". Chains enqueue an action when ready;
--     one dedicated executor coroutine dequeues and runs them one at
--     a time. This is the ONLY place isClaimingPlanter is set, so
--     there is no race condition.
--   • The executor checks ALL global blocking flags before running
--     each action and re-queues if blocked.
--   • Sprinkler, booster dispatch, and disk engine all already check
--     isClaimingPlanter so they yield while we work.
-- ─────────────────────────────────────────────────────────────

-- ── Action queue executor ─────────────────────────────────────

local function readBulbProgress(bulb)
    local ga = bulb:FindFirstChild("Gui Attach")
    local tl = ga and ga:FindFirstChild("Planter Gui")
               and ga["Planter Gui"]:FindFirstChild("Bar")
               and ga["Planter Gui"].Bar:FindFirstChild("TextLabel")
    if not tl then return nil, false, "" end
    local txt = tl.Text
    local pct = txt:match("(%d+%.?%d*)%%")
    local ready = (pct and tonumber(pct) >= 100) or (txt:lower():find("ready") ~= nil)
    return tonumber(pct), ready, txt
end

local function findBulbInField(fieldName)
    local pFolder = workspace:FindFirstChild("Planters")
    if not pFolder or not Fields[fieldName] then return nil end
    local fb = Fields[fieldName].bounds
    for _, bulb in ipairs(pFolder:GetChildren()) do
        if bulb.Name == "PlanterBulb" then
            local p = bulb.Position
            if p.X >= fb.x1 and p.X <= fb.x2 and p.Z >= fb.z1 and p.Z <= fb.z2 then
                return bulb
            end
        end
    end
    return nil
end

local function collectPlanterRewards(pField, hrp, hum)
    if not Fields[pField] then return end
    local rewards = {}
    for _, obj in ipairs(workspace.Collectibles:GetChildren()) do
        if obj:IsA("BasePart") then
            local fb  = Fields[pField].bounds
            local pos = obj.Position
            if pos.X >= fb.x1 and pos.X <= fb.x2 and pos.Z >= fb.z1 and pos.Z <= fb.z2 then
                table.insert(rewards, obj)
                local partID = obj.Name
                local img = obj:FindFirstChildWhichIsA("Decal") or obj:FindFirstChildWhichIsA("SpecialMesh")
                if img then
                    local ex = tostring(img.Texture or img.MeshId or ""):match("%d+")
                    if ex then partID = ex end
                end
                totalPlanterRewards[partID] = (totalPlanterRewards[partID] or 0) + 1
                if not assetNameCache[partID] then
                    task.spawn(function() getAssetName(partID) end)
                end
            end
        end
    end
    local tStart = tick()
    for _, token in ipairs(rewards) do
        if tick() - tStart > 15 then break end
        while token and token.Parent and tick() - tStart <= 15 do
            if stepToward(hrp, hum, token.Position, 4) then break end
            task.wait(0.05)
        end
    end
end

-- Update the status text of a chain (by id, not index)
local function setChainStatusById(chainId, txt)
    local ci, ch = findChainById(chainId)
    if ch then ch.status = txt end
    -- Update UI label if it exists and still matches this chain's current index
    if ci and UI.chainUIRefs and UI.chainUIRefs[ci] then
        local ref = UI.chainUIRefs[ci]
        if ref.statusLbl then ref.statusLbl.Text = txt end
    end
end

-- ── Global blocking check ─────────────────────────────────────
-- Returns true if the character is busy with something else entirely
local function isBusy()
    return isConverting
        or activeBooster
        or isCheckingBoosters
        or isSolvingMM
        or warnDisks.processing
end

-- ── Action queue executor ─────────────────────────────────────
-- Runs in its own coroutine. Pops one action at a time, waits for
-- all blocking conditions to clear, then runs the action.
task.spawn(function()
    while _G.Running do
        task.wait(0.5)

        if #planterActionQueue == 0 then continue end
        if planterQueueRunning   then continue end
        if not isFarming         then continue end
        if isBusy()              then continue end

        -- Pop the next action
        local entry = table.remove(planterActionQueue, 1)
        if not entry then continue end

        -- Wait again in case something started between pop and execution
        local waitStart = tick()
        while isBusy() or not isFarming do
            if tick() - waitStart > 30 then break end -- safety timeout
            task.wait(0.5)
        end
        if not isFarming then
            -- Re-queue and try later
            table.insert(planterActionQueue, 1, entry)
            continue
        end

        planterQueueRunning  = true
        isClaimingPlanter    = true

        local ok, err = pcall(entry.fn)
        if not ok then
            warn("[BlueHive] Planter action error: "..tostring(err))
        end

        isClaimingPlanter   = false
        planterQueueRunning = false

        -- Small gap between actions so the game can settle
        task.wait(1)
    end
end)

-- ── Chain watcher coroutines ──────────────────────────────────
-- Each chain gets one coroutine spawned when it's created (keyed by chain.id).
-- The coroutine loops, checking its field every 2 seconds, and enqueues
-- actions when needed. It never moves the character itself.

local spawnedChainIds = {}  -- set of chain ids that already have a coroutine

local function watchChain(chainId)
    while _G.Running do
        task.wait(2)

        -- Find this chain by id (index may have changed due to deletions)
        local ci, chain = findChainById(chainId)
        if not chain then break end  -- chain was deleted, exit coroutine

        -- Master off or chain off
        if not planterChainsEnabled or not chain.enabled then
            setChainStatusById(chainId, "off")
            continue
        end

        if not isFarming then
            setChainStatusById(chainId, "waiting")
            continue
        end

        local slots = chain.slots
        if not slots or #slots == 0 then
            setChainStatusById(chainId, "no slots")
            continue
        end

        -- Clamp slot index
        if chain.currentSlot > #slots then chain.currentSlot = 1 end
        local si    = chain.currentSlot
        local slot  = slots[si]
        local field = slot.field
        local fData = Fields[field]

        if not fData then
            setChainStatusById(chainId, "bad field")
            continue
        end

        -- Check if this chain already has a pending action in the queue
        -- (avoid stacking duplicate actions)
        local alreadyQueued = false
        for _, e in ipairs(planterActionQueue) do
            if e.chainId == chainId then alreadyQueued = true; break end
        end
        if alreadyQueued then
            setChainStatusById(chainId, "queued")
            continue
        end

        -- Also skip if the executor is currently running THIS chain's action
        if planterQueueRunning and planterActionQueue[1] and planterActionQueue[1].chainId == chainId then
            continue
        end

        -- Look for a bulb in this chain's current slot's field
        local bulb = findBulbInField(field)

        if not bulb then
            -- No bulb — enqueue a PLACE action
            setChainStatusById(chainId, "needs planting")
            table.insert(planterActionQueue, {
                chainId = chainId,
                fn = function()
                    -- Re-fetch chain in case it changed while queued
                    local _, ch = findChainById(chainId)
                    if not ch or not ch.enabled or not planterChainsEnabled then return end
                    local s = ch.slots[ch.currentSlot]
                    if not s then return end
                    local fd = Fields[s.field]
                    if not fd then return end

                    setChainStatusById(chainId, "placing…")
                    tpTo(fd.center); anchor(); task.wait(1.5)
                    pcall(function()
                        RepStorage.Events.PlayerActivesCommand:FireServer({ Name = s.planterName })
                    end)
                    task.wait(2)
                    unanchor(); tpTo(fieldCenter())
                    setChainStatusById(chainId, "growing")
                end
            })

        else
            -- Bulb exists — read its progress
            local pct, ready = readBulbProgress(bulb)
            local threshold  = slot.claimPct or 100

            if ready or (pct and pct >= threshold) then
                -- Enqueue a CLAIM+REPLANT action
                setChainStatusById(chainId, "ready to claim")
                table.insert(planterActionQueue, {
                    chainId = chainId,
                    fn = function()
                        local _, ch = findChainById(chainId)
                        if not ch or not ch.enabled or not planterChainsEnabled then return end
                        local s      = ch.slots[ch.currentSlot]
                        if not s then return end
                        local fd     = Fields[s.field]
                        if not fd then return end

                        -- Re-check the bulb still exists
                        local b2 = findBulbInField(s.field)
                        if not b2 then
                            -- Already gone (another script/player claimed it?)
                            setChainStatusById(chainId, "growing")
                            return
                        end

                        setChainStatusById(chainId, "claiming…")
                        local _, hrp, hum = getChar()
                        tpTo(b2.Position); anchor(); task.wait(1.5)
                        pressE(); unanchor(); task.wait(3)

                        -- Collect rewards
                        collectPlanterRewards(s.field, hrp, hum)
                        hum.WalkToPoint = hrp.Position

                        -- Advance slot
                        local slots2  = ch.slots
                        local nextSi  = (ch.currentSlot % #slots2) + 1
                        ch.currentSlot = nextSi
                        savePlanterConfig()
                        local ns      = slots2[nextSi]
                        local nfd     = ns and Fields[ns.field]

                        -- Plant next slot's planter
                        if ns and nfd then
                            if ns.field == s.field then
                                -- Same field, plant here
                                tpTo(b2.Position); anchor(); task.wait(1)
                                pcall(function()
                                    RepStorage.Events.PlayerActivesCommand:FireServer({ Name = ns.planterName })
                                end)
                                task.wait(2)
                            else
                                -- Different field
                                tpTo(nfd.center); anchor(); task.wait(1.5)
                                pcall(function()
                                    RepStorage.Events.PlayerActivesCommand:FireServer({ Name = ns.planterName })
                                end)
                                task.wait(2)
                            end
                        end

                        unanchor(); tpTo(fieldCenter())
                        setChainStatusById(chainId, "growing")

                        -- Refresh UI highlight for new active slot
                        if UI.rebuildChainUI then UI.rebuildChainUI() end
                    end
                })

            else
                -- Still growing — just update status, no action needed
                local pctStr = pct and string.format("%.0f", pct) or "?"
                setChainStatusById(chainId, pctStr.."% / "..threshold.."%")
            end
        end
    end
    -- Coroutine exiting (chain deleted) — clean up spawned set
    spawnedChainIds[chainId] = nil
end

-- Planter monitor: update planterProgress display from live bulbs
task.spawn(function()
    while _G.Running do
        task.wait(2)
        local pFolder = workspace:FindFirstChild("Planters")
        if not pFolder then continue end
        local seen = {}
        for _, bulb in ipairs(pFolder:GetChildren()) do
