// GRAPH WINDOWS
// ─────────────────────────────────────────────────────────────────────────────
let _winId = 0;
const graphWindows = [];

const WIN_SERIES_DEFS = [
  {{ key:'hps',           label:'H/s avg',       color:'#f5c542' }},
  {{ key:'current_hps',   label:'H/s current',   color:'#ffe082' }},
  {{ key:'pps',           label:'P/s avg',        color:'#4fc3f7' }},
  {{ key:'current_pps',   label:'P/s current',    color:'#80deea' }},
  {{ key:'honey',         label:'Total Honey',    color:'#ffb74d', normalize:true }},
  {{ key:'pollen',        label:'Pollen in Bag',  color:'#81c784' }},
  {{ key:'capacity',      label:'Capacity',       color:'#ce93d8' }},
  {{ key:'balloon_pollen',label:'Balloon Pollen', color:'#f06292' }},
];

function addGraphWindow(preset) {{
  const id = ++_winId;
  const win = {{
    id,
    title: preset?.title || ('Window ' + id),
    collapsed: false,
    series: WIN_SERIES_DEFS.map((s, i) => ({{...s, on: i === 0}})),
  }};
  graphWindows.push(win);
  rebuildWindowsContainer();
  renderWindowGraph(win.id);
}}

function removeWindow(id) {{
  const i = graphWindows.findIndex(w => w.id === id);
  if (i >= 0) graphWindows.splice(i, 1);
  rebuildWindowsContainer();
}}

function collapseAllWindows() {{ graphWindows.forEach(w => w.collapsed = true); rebuildWindowsContainer(); }}
function expandAllWindows()   {{ graphWindows.forEach(w => w.collapsed = false); rebuildWindowsContainer(); rebuildWindowsContainer(); graphWindows.forEach(w => renderWindowGraph(w.id)); }}

function rebuildWindowsContainer() {{
  const container = document.getElementById('windowsContainer');
  if (!container) return;
  if (!graphWindows.length) {{
    container.innerHTML = '<div class="empty-state"><div class="icon">📊</div>No windows yet — click + Add Window.</div>';
    return;
  }}
  container.innerHTML = '';
  graphWindows.forEach(win => {{
    const card = document.createElement('div');
    card.className = 'win-card';
    card.id = 'win-' + win.id;

    const seriesHTML = win.series.map((s, i) => `
      <label class="series-pill ${{s.on ? 'on' : ''}}" id="wsp-${{win.id}}-${{i}}">
        <input type="checkbox" ${{s.on ? 'checked' : ''}} onchange="(function(cb,wid,si){{
          graphWindows.find(w=>w.id===wid).series[si].on=cb.checked;
          cb.closest('label').classList.toggle('on',cb.checked);
          renderWindowGraph(wid);
        }})(this,${{win.id}},${{i}})">
        <input type="color" value="${{s.color}}" onclick="event.stopPropagation()"
          oninput="(function(v,wid,si){{
            graphWindows.find(w=>w.id===wid).series[si].color=v;
            renderWindowGraph(wid);
          }})(this.value,${{win.id}},${{i}})">
        ${{s.label}}
      </label>`).join('');

    card.innerHTML = `
      <div class="win-controls">
        <input class="win-title-input" value="${{win.title}}"
          oninput="graphWindows.find(w=>w.id===${{win.id}}).title=this.value">
        <div style="display:flex;gap:6px">
          <button class="btn" onclick="(function(wid){{
            const w=graphWindows.find(x=>x.id===wid);
            w.collapsed=!w.collapsed;
            rebuildWindowsContainer();
            if(!w.collapsed)renderWindowGraph(wid);
          }})(${{win.id}})">${{win.collapsed ? '▼ Expand' : '▲ Collapse'}}</button>
          <button class="btn danger" onclick="removeWindow(${{win.id}})">✕ Remove</button>
        </div>
      </div>
      ${{win.collapsed ? '<div style="color:var(--muted);font-size:12px;font-family:var(--font-mono)">Collapsed</div>' : `
        <div class="win-series-row">${{seriesHTML}}</div>
        <div class="chart-div" id="wingraph-${{win.id}}"></div>
      `}}`;
    container.appendChild(card);
  }});
}}

function renderWindowGraph(id) {{
  const win = graphWindows.find(w => w.id === id);
  const el  = document.getElementById('wingraph-' + id);
  if (!win || !el) return;
  const s  = activeLog();
  const ts = s.stats.timestamps;
  const shapes = addConvertingShapes(s);
  const traces = [];
  const layout = {{ ...PLOTLY_LAYOUT_BASE, height: 300, shapes }};
  let axIdx = 1;

  win.series.filter(sr => sr.on).forEach(sr => {{
    let data = s.stats[sr.key];
    if (!data || !data.length) return;
    if (sr.normalize) {{ const base = data[0] || 0; data = data.map(v => v - base); }}
    const ykey = axIdx === 1 ? 'y' : 'y' + axIdx;
    if (axIdx > 1) {{
      layout['yaxis' + axIdx] = {{
        ...PLOTLY_LAYOUT_BASE.yaxis,
        overlaying: 'y',
        side: axIdx % 2 === 0 ? 'right' : 'left',
        showgrid: false,
      }};
      layout.margin = {{ t:10, b:40, l:60, r:60 }};
    }}
    traces.push({{
      x: ts, y: data, name: sr.label, type: 'scatter', mode: 'lines',
      line: {{ color: sr.color, width: 2, shape: 'spline', smoothing: 0.4 }},
      fill: axIdx === 1 ? 'tozeroy' : 'none',
      fillcolor: axIdx === 1 ? hexToRgba(sr.color, 0.06) : undefined,
      yaxis: ykey,
      hovertemplate: `%{{y:.1f}}<extra>${{sr.label}}</extra>`,
    }});
    axIdx++;
  }});

  if (!traces.length) {{
    el.innerHTML = '<div style="padding:30px;text-align:center;color:var(--muted);font-family:var(--font-mono);font-size:12px">No series selected.</div>';
    return;
  }}
  Plotly.newPlot('wingraph-' + id, traces, layout, PLOTLY_CONFIG);
}}

