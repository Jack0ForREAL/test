function filterTiles() {{
  const q = document.getElementById('tileSearch').value.toLowerCase();
  document.querySelectorAll('#tileGrid .tile-card').forEach(card => {{
    const name = card.querySelector('.tile-name')?.textContent.toLowerCase() || '';
    const id   = card.querySelector('.tile-id')?.textContent.toLowerCase() || '';
    card.style.display = (name.includes(q) || id.includes(q)) ? '' : 'none';
  }});
}}

function toggleTileSelect(id) {{
  if (selectedTiles.has(id)) selectedTiles.delete(id);
  else selectedTiles.add(id);
  const card = document.getElementById('tc-' + id);
  if (card) card.classList.toggle('selected', selectedTiles.has(id));
}}

function clearTileSelection() {{
  selectedTiles.clear();
  document.querySelectorAll('.tile-card.selected').forEach(c => c.classList.remove('selected'));
}}

function setTileColor(id, color) {{
  tileColors[id] = color;
}}

function ignoreTile(id, name) {{
  event.preventDefault();
  ignoreList.add(id);
  selectedTiles.delete(id);
  renderTileBrowser(activeLog());
  renderIgnoreChips();
  toast(`Ignored: ${{name}}`);
}}

function renderIgnoreChips() {{
  const container = document.getElementById('ignoreChips');
  if (!ignoreList.size) {{
    container.innerHTML = '<span class="empty-ignore">None ignored</span>';
    return;
  }}
  container.innerHTML = [...ignoreList].map(id => {{
    const log  = activeLog();
    const tile = (log.tile_summaries||[]).find(t => t.asset_id === id);
    const label = tile ? tile.name : id;
    return `<div class="ignore-chip">
      ${{label}}
      <button onclick="unignoreTile('${{id}}')" title="Remove from ignore">×</button>
    </div>`;
  }}).join('');
}}

function unignoreTile(id) {{
  ignoreList.delete(id);
  renderTileBrowser(activeLog());
  renderIgnoreChips();
}}

function graphSelected() {{
  if (!selectedTiles.size) {{ toast('Select at least one tile first'); return; }}
  showPage('tilegraphs', document.querySelector('.nav-btn[onclick*="tilegraphs"]'));
  renderTileGraphs();
}}

