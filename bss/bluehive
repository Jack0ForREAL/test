    chainOuterPad.PaddingBottom = UDim.new(0, 4)

    -- ── Pixel widths for slot row columns (total = card inner width) ─
    -- Card inner width ≈ (tab width) - 2*outer_pad - 2*card_pad
    -- We use pixel offsets from left edge of slotRow:
    --   [0..11]   = slot number label  (12px)
    --   [12..end-60] = planter btn
    --   [end-58..end-22] = field btn   (36px wide)
    --   [end-20..end-10] = % box       (24px wide … actually use 30)
    --   last 18px = ✕ button
    -- Easier to just use absolute pixel positions keyed off 0:

    local COL_NUM_W   = 12   -- slot number
    local COL_DEL_W   = 18   -- ✕ button (rightmost)
    local COL_PCT_W   = 28   -- % box
    local COL_FIELD_W = 80   -- field dropdown
    -- planter btn fills the rest

    -- ── Helper: make a simple cycling dropdown (no LayoutOrder, no parent layout) ─
    local function mkDropdown(parent, values, initVal, x, y, w, h)
        local idx = 1
        for i, v in ipairs(values) do if v == initVal then idx = i; break end end
        local btn = Instance.new("TextButton", parent)
        btn.Position         = UDim2.new(0, x, 0, y)
        btn.Size             = UDim2.new(0, w, 0, h)
        btn.BackgroundColor3 = C.bg
        btn.BorderSizePixel  = 0
        btn.Text             = values[idx]
        btn.TextColor3       = C.accent
        btn.Font             = Enum.Font.Gotham
        btn.TextSize         = 8
        btn.TextTruncate     = Enum.TextTruncate.AtEnd
        btn.ClipsDescendants = true
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 3)
        local pad = Instance.new("UIPadding", btn)
        pad.PaddingLeft  = UDim.new(0, 3)
        pad.PaddingRight = UDim.new(0, 3)
        btn.MouseButton1Click:Connect(function()
            idx = (idx % #values) + 1
            btn.Text = values[idx]
        end)
        return btn, function() return values[idx] end
    end

    -- ── Chain card builder ────────────────────────────────────
    local chainFrameRefs = {}
    local chainUIRefs    = {}

    local function rebuildChainUI()
        for _, f in ipairs(chainFrameRefs) do
            if f and f.Parent then f:Destroy() end
        end
        chainFrameRefs = {}
        chainUIRefs    = {}

        -- One card per chain
        for ci, chain in ipairs(planterChains) do
            local capturedId = chain.id

            -- Card frame — AutomaticSize so it grows with slots
            local card = Instance.new("Frame", chainOuterScroll)
            card.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
            card.BorderSizePixel  = 0
            card.LayoutOrder      = ci
            card.AutomaticSize    = Enum.AutomaticSize.Y
            card.Size             = UDim2.new(1, 0, 0, 0)
            Instance.new("UICorner", card).CornerRadius = UDim.new(0, 6)
            local stroke = Instance.new("UIStroke", card)
            stroke.Color     = chain.enabled and C.accent or C.border
            stroke.Thickness = 1

            -- Card list layout
            local cardList = Instance.new("UIListLayout", card)
            cardList.Padding   = UDim.new(0, 2)
            cardList.SortOrder = Enum.SortOrder.LayoutOrder
            local cardPad = Instance.new("UIPadding", card)
            cardPad.PaddingLeft   = UDim.new(0, 5)
            cardPad.PaddingRight  = UDim.new(0, 5)
            cardPad.PaddingTop    = UDim.new(0, 4)
            cardPad.PaddingBottom = UDim.new(0, 4)

            -- ── Header row ──────────────────────────────────
            local hdr = Instance.new("Frame", card)
            hdr.Size             = UDim2.new(1, 0, 0, 18)
            hdr.BackgroundTransparency = 1
            hdr.LayoutOrder      = 1

            -- "Cycle #N" label
            local cycLbl = Instance.new("TextLabel", hdr)
            cycLbl.Size                 = UDim2.new(0, 56, 1, 0)
            cycLbl.Position             = UDim2.new(0, 0, 0, 0)
            cycLbl.BackgroundTransparency = 1
            cycLbl.Text                 = "Cycle #"..ci
            cycLbl.TextColor3           = chain.enabled and C.accent or C.textDim
            cycLbl.Font                 = Enum.Font.GothamBold
            cycLbl.TextSize             = 10
            cycLbl.TextXAlignment       = Enum.TextXAlignment.Left

            -- Status label (fills middle)
            local statusLbl = Instance.new("TextLabel", hdr)
            statusLbl.Size                 = UDim2.new(1, -150, 1, 0)
            statusLbl.Position             = UDim2.new(0, 58, 0, 0)
            statusLbl.BackgroundTransparency = 1
            statusLbl.Text                 = chain.status or "—"
            statusLbl.TextColor3           = C.textDim
            statusLbl.Font                 = Enum.Font.Gotham
            statusLbl.TextSize             = 8
            statusLbl.TextXAlignment       = Enum.TextXAlignment.Left
            statusLbl.TextTruncate         = Enum.TextTruncate.AtEnd

            -- ON/OFF toggle (right side)
            local onBtn = Instance.new("TextButton", hdr)
            onBtn.Size             = UDim2.new(0, 32, 0, 14)
            onBtn.Position         = UDim2.new(1, -88, 0.5, -7)
            onBtn.BackgroundColor3 = chain.enabled and C.greenDark or Color3.fromRGB(50,20,20)
            onBtn.BorderSizePixel  = 0
            onBtn.Text             = chain.enabled and "ON" or "OFF"
            onBtn.TextColor3       = chain.enabled and C.green or Color3.fromRGB(200,80,80)
            onBtn.Font             = Enum.Font.GothamBold
            onBtn.TextSize         = 8
            Instance.new("UICorner", onBtn).CornerRadius = UDim.new(0, 3)
            onBtn.MouseButton1Click:Connect(function()
                local _, ch = findChainById(capturedId)
                if ch then ch.enabled = not ch.enabled end
                savePlanterConfig()
                rebuildChainUI()
            end)

            -- "+ slot" button
            local addSlotBtn = Instance.new("TextButton", hdr)
            addSlotBtn.Size             = UDim2.new(0, 40, 0, 14)
            addSlotBtn.Position         = UDim2.new(1, -53, 0.5, -7)
            addSlotBtn.BackgroundColor3 = Color3.fromRGB(0, 50, 25)
            addSlotBtn.BorderSizePixel  = 0
            addSlotBtn.Text             = "+Slot"
            addSlotBtn.TextColor3       = C.green
            addSlotBtn.Font             = Enum.Font.GothamBold
            addSlotBtn.TextSize         = 8
            Instance.new("UICorner", addSlotBtn).CornerRadius = UDim.new(0, 3)
            addSlotBtn.MouseButton1Click:Connect(function()
                local _, ch = findChainById(capturedId)
                if ch then
                    table.insert(ch.slots, {
                        planterName = PlanterNames[1],
                        field       = FieldOrder[1],
                        claimPct    = 100,
                    })
                end
                savePlanterConfig()
                rebuildChainUI()
            end)

            -- ✕ remove chain button
            local delChainBtn = Instance.new("TextButton", hdr)
            delChainBtn.Size             = UDim2.new(0, 10, 0, 14)
            delChainBtn.Position         = UDim2.new(1, -10, 0.5, -7)
            delChainBtn.BackgroundTransparency = 1
            delChainBtn.BorderSizePixel  = 0
            delChainBtn.Text             = "✕"
            delChainBtn.TextColor3       = C.textDim
            delChainBtn.Font             = Enum.Font.GothamBold
            delChainBtn.TextSize         = 9
            delChainBtn.MouseButton1Click:Connect(function()
                for qi = #planterActionQueue, 1, -1 do
                    if planterActionQueue[qi].chainId == capturedId then
                        table.remove(planterActionQueue, qi)
                    end
                end
                for rci, ch in ipairs(planterChains) do
                    if ch.id == capturedId then
                        table.remove(planterChains, rci); break
                    end
                end
                savePlanterConfig()
                rebuildChainUI()
            end)

            -- ── Column header row ────────────────────────────
            local colHdr = Instance.new("Frame", card)
            colHdr.Size             = UDim2.new(1, 0, 0, 12)
            colHdr.BackgroundTransparency = 1
            colHdr.LayoutOrder      = 2
            local function mkColLbl(txt, xpx, wpx)
                local l = Instance.new("TextLabel", colHdr)
                l.Size                 = UDim2.new(0, wpx, 1, 0)
                l.Position             = UDim2.new(0, xpx, 0, 0)
                l.BackgroundTransparency = 1
                l.Text                 = txt
                l.TextColor3           = C.textDim
                l.Font                 = Enum.Font.GothamBold
                l.TextSize             = 7
                l.TextXAlignment       = Enum.TextXAlignment.Left
            end
            mkColLbl("#",       0,                    COL_NUM_W)
            mkColLbl("PLANTER", COL_NUM_W + 2,        80)
            mkColLbl("FIELD",   COL_NUM_W + 80 + 4,   COL_FIELD_W)
            mkColLbl("%",       COL_NUM_W + 80 + 4 + COL_FIELD_W + 2, COL_PCT_W)

            -- ── Slot rows ────────────────────────────────────
            local slotRefs = {}
            for si, slot in ipairs(chain.slots) do
                local isActive = planterChainsEnabled and chain.enabled and (si == chain.currentSlot)
                local capturedSi = si

                local row = Instance.new("Frame", card)
                row.Size             = UDim2.new(1, 0, 0, 20)
                row.BackgroundColor3 = Color3.fromRGB(0, 40, 22)
                row.BackgroundTransparency = isActive and 0 or 1
                row.BorderSizePixel  = 0
                row.LayoutOrder      = si + 2
                Instance.new("UICorner", row).CornerRadius = UDim.new(0, 3)
                row.ClipsDescendants = true

                -- slot number
                local numLbl = Instance.new("TextLabel", row)
                numLbl.Size                 = UDim2.new(0, COL_NUM_W, 1, 0)
                numLbl.Position             = UDim2.new(0, 0, 0, 0)
                numLbl.BackgroundTransparency = 1
                numLbl.Text                 = tostring(si)
                numLbl.TextColor3           = isActive and C.green or C.textDim
                numLbl.Font                 = Enum.Font.GothamBold
                numLbl.TextSize             = 8
                numLbl.TextXAlignment       = Enum.TextXAlignment.Center

                -- ── All remaining columns use absolute pixel X ─
                local x = COL_NUM_W + 2
                local rowH = 18  -- content height inside 20px row

                -- planter dropdown
                local planterW = 78
                local pDrop, getPName = mkDropdown(row, PlanterNames, slot.planterName, x, 1, planterW, rowH)
                pDrop.MouseButton1Click:Connect(function()
                    local _, ch = findChainById(capturedId)
                    if ch and ch.slots[capturedSi] then
                        ch.slots[capturedSi].planterName = getPName()
                        savePlanterConfig()
                    end
                end)
                x = x + planterW + 3

                -- field dropdown
                local fDrop, getFName = mkDropdown(row, FieldOrder, slot.field, x, 1, COL_FIELD_W, rowH)
                fDrop.MouseButton1Click:Connect(function()
                    local _, ch = findChainById(capturedId)
                    if ch and ch.slots[capturedSi] then
                        ch.slots[capturedSi].field = getFName()
                        savePlanterConfig()
                    end
                end)
                x = x + COL_FIELD_W + 3

                -- % textbox
                local pctBox = Instance.new("TextBox", row)
                pctBox.Position         = UDim2.new(0, x, 0, 1)
                pctBox.Size             = UDim2.new(0, COL_PCT_W, 0, rowH)
                pctBox.BackgroundColor3 = C.bg
                pctBox.BorderSizePixel  = 0
                pctBox.Text             = tostring(slot.claimPct)
                pctBox.TextColor3       = C.honey
                pctBox.Font             = Enum.Font.GothamBold
                pctBox.TextSize         = 8
                Instance.new("UICorner", pctBox).CornerRadius = UDim.new(0, 3)
                local pp = Instance.new("UIPadding", pctBox)
                pp.PaddingLeft = UDim.new(0, 3)
                pctBox.FocusLost:Connect(function()
                    local v = math.clamp(tonumber(pctBox.Text:match("[%d%.]+")) or 100, 1, 100)
                    local _, ch = findChainById(capturedId)
                    if ch and ch.slots[capturedSi] then
                        ch.slots[capturedSi].claimPct = v
                        savePlanterConfig()
                    end
                    pctBox.Text = tostring(v)
                end)
                x = x + COL_PCT_W + 3

                -- ✕ remove slot
                local delSlot = Instance.new("TextButton", row)
                delSlot.Position         = UDim2.new(0, x, 0, 1)
                delSlot.Size             = UDim2.new(0, COL_DEL_W, 0, rowH)
                delSlot.BackgroundTransparency = 1
                delSlot.BorderSizePixel  = 0
                delSlot.Text             = "✕"
                delSlot.TextColor3       = C.textDim
                delSlot.Font             = Enum.Font.GothamBold
                delSlot.TextSize         = 9
                delSlot.MouseButton1Click:Connect(function()
                    local _, ch = findChainById(capturedId)
                    if not ch or #ch.slots <= 1 then return end
                    table.remove(ch.slots, capturedSi)
                    if ch.currentSlot > #ch.slots then ch.currentSlot = 1 end
                    savePlanterConfig()
                    rebuildChainUI()
                end)

                table.insert(slotRefs, row)
            end

            table.insert(chainFrameRefs, card)
            chainUIRefs[ci] = { statusLbl = statusLbl, slotRefs = slotRefs }
        end

        -- ── "+ Add Cycle" button — always present at bottom ────
        local addCycleBtn = Instance.new("TextButton", chainOuterScroll)
        addCycleBtn.Size             = UDim2.new(1, 0, 0, 24)
        addCycleBtn.BackgroundColor3 = Color3.fromRGB(0, 38, 18)
        addCycleBtn.BorderSizePixel  = 0
        addCycleBtn.Text             = "+ Add Cycle"
        addCycleBtn.TextColor3       = C.green
        addCycleBtn.Font             = Enum.Font.GothamBold
        addCycleBtn.TextSize         = 11
        addCycleBtn.LayoutOrder      = 999
        Instance.new("UICorner", addCycleBtn).CornerRadius = UDim.new(0, 5)
        addCycleBtn.MouseButton1Click:Connect(function()
            table.insert(planterChains, {
                id          = newChainId(),
                enabled     = false,
                slots       = {{ planterName=PlanterNames[1], field=FieldOrder[1], claimPct=100 }},
                currentSlot = 1,
                status      = "—",
            })
            savePlanterConfig()
            rebuildChainUI()
        end)
        table.insert(chainFrameRefs, addCycleBtn)
    end

    -- Master toggle logic
    masterToggleBtn.MouseButton1Click:Connect(function()
        planterChainsEnabled = not planterChainsEnabled
        masterToggleBtn.Text             = planterChainsEnabled and "🌱 Auto-Plant: ON"  or "🌱 Auto-Plant: OFF"
        masterToggleBtn.BackgroundColor3 = planterChainsEnabled and C.greenDark or C.card
        masterToggleBtn.TextColor3       = planterChainsEnabled and C.green     or C.text
        rebuildChainUI()
    end)

    rebuildChainUI()   -- draw initial state (just the "+ Add Cycle" button)

    -- ════════════════════════════════════════════════════════
    -- CFG TAB
    -- ════════════════════════════════════════════════════════
    local cfgTab = tabFrames["CFG"]

    local cfgSplit = Instance.new("Frame", cfgTab)
    cfgSplit.Size             = UDim2.new(1, 0, 0, CONTENT_H - 10)
    cfgSplit.BackgroundTransparency = 1
    cfgSplit.BorderSizePixel  = 0
    cfgSplit.LayoutOrder      = 1

    local cfgLeft = Instance.new("Frame", cfgSplit)
    cfgLeft.Size             = UDim2.new(0.5, -4, 1, 0)
    cfgLeft.BackgroundTransparency = 1
    cfgLeft.BorderSizePixel  = 0
    local cfgLLay = Instance.new("UIListLayout", cfgLeft)
    cfgLLay.Padding = UDim.new(0, 4); cfgLLay.SortOrder = Enum.SortOrder.LayoutOrder

    local cfgRight = Instance.new("Frame", cfgSplit)
    cfgRight.Size             = UDim2.new(0.5, -2, 1, 0)
    cfgRight.Position         = UDim2.new(0.5, 6, 0, 0)
    cfgRight.BackgroundTransparency = 1
    cfgRight.BorderSizePixel  = 0
    local cfgRLay = Instance.new("UIListLayout", cfgRight)
    cfgRLay.Padding = UDim.new(0, 4); cfgRLay.SortOrder = Enum.SortOrder.LayoutOrder

    mkHeader(cfgLeft, "🎈 BALLOON", 1)
    local balloonForeverBtn = mkButton(cfgLeft, "Ignore: OFF (claim)", C.greenDark, 2, 24)
    balloonForeverBtn.TextSize = 10
    mkLabel(cfgLeft, "Timed ignore:", C.textDim, 3, 14)
    local balloonTimeBox = mkTextBox(cfgLeft, "30m, 2h…", 4)
    local balloonStatusLbl = mkLabel(cfgLeft, "  Inactive", Color3.fromRGB(100, 150, 100), 5, 14)
    balloonStatusLbl.TextSize = 10

    mkDivider(cfgLeft, 6)
    mkHeader(cfgLeft, "🌺 BLOOMS & PETALS", 7)
    local bloomBtn = mkButton(cfgLeft, "Collect: ON", C.greenDark, 8, 24)
    bloomBtn.TextSize = 10

    mkHeader(cfgRight, "🔍 UI SCALE", 1)
    local scaleBox = mkTextBox(cfgRight, "0.4 – 2.5", 2)
    scaleBox.Text = "1.0"

    -- CFG logic
    bloomBtn.MouseButton1Click:Connect(function()
        collectBlooms             = not collectBlooms
        bloomBtn.Text             = collectBlooms and "Collect: ON" or "Collect: OFF"
        bloomBtn.BackgroundColor3 = collectBlooms and C.greenDark or C.redDark
    end)

    balloonForeverBtn.MouseButton1Click:Connect(function()
        ignoreBalloonEver              = not ignoreBalloonEver
        balloonForeverBtn.Text         = ignoreBalloonEver and "Ignore: ON  (skip)" or "Ignore: OFF (claim)"
        balloonForeverBtn.BackgroundColor3 = ignoreBalloonEver and C.redDark or C.greenDark
    end)

    balloonTimeBox.FocusLost:Connect(function()
        local txt = balloonTimeBox.Text:lower():gsub("%s","")
        local num = tonumber(txt:match("%d+"))
        if num then
            local secs = num * (txt:find("h") and 3600 or 60)
            ignoreBalloonUntil      = tick() + secs
            balloonStatusLbl.Text   = "  Until "..os.date("%H:%M:%S", os.time()+secs)
            balloonStatusLbl.TextColor3 = C.green
        end
    end)

    scaleBox.FocusLost:Connect(function()
        local v = tonumber(scaleBox.Text:match("[%d%.]+"))
        if v then uiScale.Scale = math.clamp(v, 0.4, 2.5) end
    end)

    -- ── Start/Stop button logic ───────────────────────────────
    startBtn.MouseButton1Click:Connect(function()
        isFarming = not isFarming
        if isFarming then
            startBtn.Text             = "■  STOP FARMING"
            startBtn.BackgroundColor3 = C.redDark
            statusLbl.Text            = "Farming"
            statusLbl.TextColor3      = C.green
            statusDot.BackgroundColor3 = C.green
            intervalStart  = tick()
            intervalHoney  = LP.CoreStats.Honey.Value

            RepStorage.Events.ItemPackageEvent:InvokeServer("Equip",{["Category"]="Accessory",["Type"]="Diamond Mask"})

            balloonPollenNow  = -1
            rateHoneyHistory  = {}
            ratePollenHistory = {}
            rateHoneyStart    = 1
            ratePollenStart   = 1

            statsBuffer       = {}
            tilesBuffer       = {}
            tileStates        = {}
            assetImageDone    = {}
            sessionFolder     = nextSessionFolder()
            hourRotateTime    = tick()
            lastSaveTime      = tick()
            lastValidCapacity = LP.CoreStats.Capacity.Value
            openNewFiles()
            tileTimesFile     = ""

            if not isCheckingBoosters and not boosterScanDone then
                isCheckingBoosters = true
                task.spawn(function()
                    for _, name in ipairs(BoosterOrder) do
                        if boosterPermaIgnore[name] then continue end
                        tpTo(Boosters[name].pos)
                        anchor()
                        task.wait(1.8)

                        local sg2     = getScreenGui()
                        local abtn    = sg2 and sg2:FindFirstChild("ActivateButton")
                        local btnText = abtn and abtn:FindFirstChild("TextBox") and abtn.TextBox.Text or ""
                        local btnBG   = abtn and abtn.BackgroundColor3 or Color3.fromRGB(0,0,0)
                        local r       = math.round(btnBG.R * 255)
                        local g       = math.round(btnBG.G * 255)
                        local b       = math.round(btnBG.B * 255)
                        local cd      = parseCooldown(btnText)

                        if cd and cd > 0 then
                            setBoosterLabel(name, "cooldown", fmtTime(cd))
                            task.delay(cd, function()
                                if not boosterPermaIgnore[name] then
                                    table.insert(boosterQueue, name)
                                    setBoosterLabel(name, "ready", "READY")
                                end
                            end)
                        elseif r >= 180 and g <= 60 and b <= 60 then
                            boosterPermaIgnore[name] = true
                            setBoosterLabel(name, "unavailable")
                        else
                            table.insert(boosterQueue, name)
                            setBoosterLabel(name, "ready", "READY")
                        end
                    end
                    unanchor()
                    isCheckingBoosters = false
                    boosterScanDone    = true
                    tpTo(fieldCenter())
                end)
            end
        else
            startBtn.Text              = "▶  START FARMING"
            startBtn.BackgroundColor3  = C.greenDark
            statusLbl.Text             = "Idle"
            statusLbl.TextColor3       = C.textMid
            statusDot.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
            unanchor()
            flushCSV()
        end
    end)

    destroyBtn.MouseButton1Click:Connect(function()
        _G.Running = false
        unanchor()
        for _, c in pairs(connections) do c:Disconnect() end
        sg:Destroy()
        print("[BlueHive] Destroyed.")
    end)

    -- Store shared UI refs
    UI = {
        hS=hS, hM=hM, hH=hH,
        pS=pS, pM=pM, pH=pH,
        total=totLbl, time=timeLbl,
        mm=mmLbl,
        status=statusLbl, statusDot=statusDot,
        fieldLbl=fieldActiveLbl,
        planterProgress=planterProgressLbl,
        planterRewards=planterRewardsLbl,
        -- quick stats on farm tab
        qhS=qhS, qhH=qhH, qpS=qpS, qtot=qtot, qtim=qtim,
        -- planter chain UI (set by PLANT tab section above)
        rebuildChainUI = rebuildChainUI,
        chainUIRefs    = chainUIRefs,
    }

    switchTab("FARM")
end

createUI()

