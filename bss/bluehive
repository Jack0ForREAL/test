async function saveSnapshot() {{
  toast('Rendering all graphs… please wait');

  // 1. Force-render every page off-screen so Plotly can measure
  const allPages = ['overview','honey','capacity','balloon','combined','field','tilegraphs','windows'];
  for (const name of allPages) {{
    const el = document.getElementById('page-' + name);
    if (!el) continue;
    el.style.cssText = 'display:block!important;visibility:hidden;position:absolute;top:0;left:0;width:900px';
    renderPageSpecific(name);
    await new Promise(r => setTimeout(r, name === 'windows' ? 600 : 300));
  }}
  if (selectedTiles.size) {{ renderTileGraphs(); await new Promise(r => setTimeout(r, 400)); }}

  // 2. Convert every Plotly chart div to a static <img> (SVG)
  const chartDivs = document.querySelectorAll('.chart-div[id]');
  for (const div of chartDivs) {{
    if (!div._fullLayout) continue;
    try {{
      const w   = Math.max(div.offsetWidth || 860, 400);
      const h   = div._fullLayout.height || 300;
      const svg = await Plotly.toImage(div, {{ format: 'svg', width: w, height: h }});
      const img = document.createElement('img');
      img.src = svg;
      img.style.cssText = 'width:100%;display:block';
      div.innerHTML = '';
      div.appendChild(img);
      div.removeAttribute('id');   // prevent double-processing
    }} catch(e) {{ /* skip empty charts */ }}
  }}

  // 3. Restore page visibility, add snap class, remove scripts
  allPages.forEach(name => {{
    const el = document.getElementById('page-' + name);
    if (el) el.style.cssText = '';
  }});
  document.body.classList.add('snap');

  // Add window titles as visible headings (title inputs hidden in snap mode)
  graphWindows.forEach(win => {{
    const card = document.getElementById('win-' + win.id);
    if (!card) return;
    const existing = card.querySelector('.win-title');
    if (!existing) {{
      const h = document.createElement('div');
      h.className = 'win-title';
      h.textContent = win.title;
      card.insertBefore(h, card.firstChild);
    }}
  }});

  document.querySelectorAll('script').forEach(s => s.remove());

  // 4. Download
  const html  = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;
  const blob  = new Blob([html], {{ type: 'text/html' }});
  const url   = URL.createObjectURL(blob);
  const a     = document.createElement('a');
  const label = SESSIONS[activeSession]?.label || 'Session';
  a.href     = url;
  a.download = 'BSS_' + label.replace(/[^a-z0-9]/gi, '_') + '_snapshot.html';
  a.click();
  URL.revokeObjectURL(url);
  toast('Saved!');
}}

