                tostring(isConverting), bpStr, tostring(isClaimingPlanter)
            ))
            if now - lastSaveTime >= SAVE_INTERVAL then
                flushCSV(); lastSaveTime = now
            end
        end

        if ignoreBalloonUntil > 0 and now > ignoreBalloonUntil then
            ignoreBalloonUntil = 0
        end
    end
end)

