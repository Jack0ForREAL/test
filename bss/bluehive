# ─────────────────────────────────────────────────────────────────────────────
# DATA LOADING
# ─────────────────────────────────────────────────────────────────────────────
def find_sessions():
    if not LOG_ROOT.exists():
        print(f"Could not find {LOG_ROOT}/ — run the script from the same folder.")
        sys.exit(1)
    sessions = sorted(
        [d for d in LOG_ROOT.iterdir() if d.is_dir() and d.name.startswith("Session ")],
        key=lambda d: int(re.search(r"\d+", d.name).group())
    )
    return sessions


def load_session(session_path: Path):
    """
    Returns a list of per-hour log dicts:
      { label, stats_df, tiles_df, summary, tile_summaries }
    plus a combined entry as the first item labelled "All Hours".
    """
    stats_files = sorted(session_path.glob("stats_*.csv"))
    tiles_files = sorted(session_path.glob("tiles_*.csv"))

    # Build a map by hour-tag so stats and tiles for the same hour are paired
    def hour_tag(f):
        # e.g. stats_2026-03-02_14h.csv -> 2026-03-02_14h
        return f.stem.split("_", 1)[1]

    stats_by_hour = {}
    for f in stats_files:
        tag = hour_tag(f)
        try:
            df = pd.read_csv(f, parse_dates=["Timestamp"])
            stats_by_hour[tag] = df
        except Exception as e:
            print(f"  Warning: could not read {f}: {e}")

    tiles_by_hour = {}
    for f in tiles_files:
        tag = hour_tag(f)
        try:
            df = pd.read_csv(f, parse_dates=["Timestamp"])
            tiles_by_hour[tag] = df
        except Exception as e:
            print(f"  Warning: could not read {f}: {e}")

    all_tags = sorted(set(list(stats_by_hour.keys()) + list(tiles_by_hour.keys())))

    hour_logs = []
    all_stats_frames = []
    all_tiles_frames = []

    for tag in all_tags:
        stats = stats_by_hour.get(tag, pd.DataFrame())
        tiles = tiles_by_hour.get(tag, pd.DataFrame())

        if not stats.empty:
            stats = stats.sort_values("Timestamp").drop_duplicates("Timestamp")
            all_stats_frames.append(stats)
        if not tiles.empty:
            tiles = tiles.sort_values("Timestamp")
            all_tiles_frames.append(tiles)

        # Friendly label: "14:00 – 15:00" from the tag
        hour_match = re.search(r"(\d{2})h$", tag)
        h = int(hour_match.group(1)) if hour_match else 0
        friendly = f"{h:02d}:00 – {(h+1)%24:02d}:00"

        hour_logs.append({
            "label":          friendly,
            "tag":            tag,
            "stats":          stats,
            "tiles":          tiles,
            "summary":        summarise_stats(stats),
            "tile_summaries": summarise_tiles(tiles),
        })

    # Combined entry
    combined_stats = pd.concat(all_stats_frames, ignore_index=True).sort_values("Timestamp").drop_duplicates("Timestamp") \
        if all_stats_frames else pd.DataFrame()
    combined_tiles = pd.concat(all_tiles_frames, ignore_index=True).sort_values("Timestamp") \
        if all_tiles_frames else pd.DataFrame()

    combined = {
        "label":          "All Hours",
        "tag":            "combined",
        "stats":          combined_stats,
        "tiles":          combined_tiles,
        "summary":        summarise_stats(combined_stats),
        "tile_summaries": summarise_tiles(combined_tiles),
    }

    return combined, hour_logs


def load_asset_image(asset_name: str, asset_id: str = "") -> str:
    """Return base64 data URI for an asset image, or empty string.
    Looks for AssetName_ID.png (new format) then AssetName.png (fallback)."""
    if not ASSETS_DIR.exists():
        return ""

    def try_file(path: Path) -> str:
        try:
            data = path.read_bytes()
            b64  = base64.b64encode(data).decode()
            mime = "image/png" if path.suffix == ".png" else "image/jpeg"
            return f"data:{mime};base64,{b64}"
        except Exception:
            return ""

    # Sanitise name the same way Lua does: replace non-alphanumeric with _
    import re
    safe = re.sub(r'[\x00-\x1f\x7f\s\W]', '_', asset_name.strip())

    # Try new format: AssetName_ID.png
    if asset_id:
        for ext in [".png", ".jpg", ".jpeg", ".webp"]:
            candidates = list(ASSETS_DIR.glob(f"{safe}_{asset_id}{ext}"))
            if candidates:
                result = try_file(candidates[0])
                if result:
                    return result

    # Fallback: any file starting with the sanitised name
    for ext in [".png", ".jpg", ".jpeg", ".webp"]:
        candidates = list(ASSETS_DIR.glob(f"{safe}*{ext}"))
        if candidates:
            result = try_file(candidates[0])
            if result:
                return result

    return ""


def summarise_stats(stats: pd.DataFrame) -> dict:
    if stats.empty:
        return {}
    duration = (stats["Timestamp"].max() - stats["Timestamp"].min()).total_seconds()
    honey_gained = stats["TotalHoney"].iloc[-1] - stats["TotalHoney"].iloc[0]
    peak_hps  = stats["HPS"].max()
    avg_hps   = stats["HPS"].mean()
    peak_cap  = stats["Capacity"].max()
    converting_pct = (stats["Converting"] == True).mean() * 100  # noqa: E712

    fields = stats["Field"].value_counts().to_dict() if "Field" in stats.columns else {}

    return {
        "duration_s":      round(duration),
        "honey_gained":    int(honey_gained),
        "peak_hps":        round(peak_hps, 1),
        "avg_hps":         round(avg_hps, 1),
        "peak_capacity":   int(peak_cap),
        "converting_pct":  round(converting_pct, 1),
        "fields":          fields,
    }


def summarise_tiles(tiles: pd.DataFrame) -> list:
    """Per-tile summary: first seen, last seen, total active time, peak mult."""
    if tiles.empty:
        return []
    results = []
    for asset_id, grp in tiles.groupby("AssetID"):
        grp = grp.sort_values("Timestamp")
        name = grp["AssetName"].iloc[0]
        active = grp[grp["State"] == "Active"]
        removed = grp[grp["State"] == "Removed"]

        # Pair up Active/Removed events to compute total uptime
        total_active_s = 0
        last_active_ts = None
        for _, row in grp.iterrows():
            if row["State"] == "Active":
                last_active_ts = row["Timestamp"]
            elif row["State"] == "Removed" and last_active_ts is not None:
                total_active_s += (row["Timestamp"] - last_active_ts).total_seconds()
                last_active_ts = None

        # If still active at end of session
        if last_active_ts is not None and not grp.empty:
            total_active_s += (grp["Timestamp"].max() - last_active_ts).total_seconds()

        peak_mult = active["Multiplier"].max() if not active.empty else 0

        results.append({
            "asset_id":       str(asset_id),
            "name":           name,
            "first_seen":     grp["Timestamp"].min().isoformat(),
            "last_seen":      grp["Timestamp"].max().isoformat(),
            "total_active_s": round(total_active_s),
            "appearances":    len(active),
            "peak_mult":      int(peak_mult),
            "image":          load_asset_image(name, str(asset_id)),
            "timestamps":     [t.isoformat() for t in grp["Timestamp"].tolist()],
            "states":         grp["State"].tolist(),
            "multipliers":    grp["Multiplier"].tolist(),
        })

    results.sort(key=lambda x: x["total_active_s"], reverse=True)
    return results


def fmt_duration(seconds: int) -> str:
    h = seconds // 3600
    m = (seconds % 3600) // 60
    s = seconds % 60
    if h > 0:
        return f"{h}h {m}m {s}s"
    if m > 0:
        return f"{m}m {s}s"
    return f"{s}s"


def fmt_number(n) -> str:
    n = int(n)
    if n >= 1_000_000_000:
        return f"{n/1_000_000_000:.2f}B"
    if n >= 1_000_000:
        return f"{n/1_000_000:.2f}M"
    if n >= 1_000:
        return f"{n/1_000:.1f}K"
    return str(n)


# ─────────────────────────────────────────────────────────────────────────────
# HTML GENERATION
# ─────────────────────────────────────────────────────────────────────────────
def serialize_log(log: dict) -> dict:
    """Convert a log dict (combined or hour) to JSON-safe form."""
    stats = log["stats"]
    def col(name):
        return stats[name].tolist() if name in stats.columns and not stats.empty else []
    def col_numeric(name):
        if name not in stats.columns or stats.empty:
            return []
        return pd.to_numeric(stats[name], errors="coerce").tolist()

    return {
        "label":          log["label"],
        "summary":        log["summary"],
        "tile_summaries": log["tile_summaries"],
        "stats": {
            "timestamps":     [t.isoformat() for t in stats["Timestamp"].tolist()] if not stats.empty else [],
            "honey":          col("TotalHoney"),
            "hps":            col("HPS"),
            "current_hps":    col_numeric("CurrentHPS"),
            "pps":            col("PPS"),
            "current_pps":    col_numeric("CurrentPPS"),
            "capacity":       col("Capacity"),
            "pollen":         col("Pollen"),
            "converting":     col("Converting"),
            "field":          col("Field"),
            "balloon_pollen": col_numeric("BalloonPollen"),
        }
    }


def build_html(sessions_data: list, session_labels: list) -> str:
