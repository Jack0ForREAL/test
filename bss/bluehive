  border-radius: var(--radius);
  padding: 20px;
  margin-bottom: 20px;
}}
.graph-builder h3 {{
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 14px;
  font-family: var(--font-mono);
}}
.graph-mode-row {{
  display: flex;
  gap: 8px;
  margin-bottom: 14px;
  flex-wrap: wrap;
}}
.mode-btn {{
  padding: 6px 12px;
  border-radius: 6px;
  border: 1px solid var(--border);
  background: var(--surface2);
  color: var(--muted);
  font-size: 11px;
  font-family: var(--font-mono);
  cursor: pointer;
  transition: all 0.15s;
}}
.mode-btn.active {{ border-color: var(--accent2); color: var(--accent2); background: rgba(79,195,247,0.08); }}

/* ── Field breakdown ── */
.field-list {{
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-top: 8px;
}}
.field-row {{
  display: flex;
  align-items: center;
  gap: 10px;
}}
.field-bar-bg {{
  flex: 1;
  height: 6px;
  background: var(--surface2);
  border-radius: 3px;
  overflow: hidden;
}}
.field-bar-fill {{
  height: 100%;
  background: var(--accent);
  border-radius: 3px;
  transition: width 0.6s ease;
}}
.field-name {{
  font-size: 11px;
  color: var(--text);
  font-family: var(--font-mono);
  width: 140px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}}
.field-pct {{
  font-size: 11px;
  color: var(--muted);
  font-family: var(--font-mono);
  width: 38px;
  text-align: right;
}}

/* ── Empty state ── */
.empty-state {{
  text-align: center;
  padding: 60px 20px;
  color: var(--muted);
  font-family: var(--font-mono);
  font-size: 13px;
}}
.empty-state .icon {{ font-size: 40px; margin-bottom: 12px; }}

/* ── Toast ── */
#toast {{
  position: fixed;
  bottom: 24px; right: 24px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 16px;
  font-size: 12px;
  font-family: var(--font-mono);
  color: var(--text);
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.2s, transform 0.2s;
  pointer-events: none;
  z-index: 9999;
}}
#toast.show {{ opacity: 1; transform: translateY(0); }}

/* ── Snap / export mode ── */
.snap .sidebar, .snap .session-tabs, .snap #logNav,
.snap .tile-controls, .snap .graph-builder, .snap .ignore-panel,
.snap .chart-controls, .snap #comboSeriesRow, .snap .tile-color-row,
.snap .win-controls, .snap .win-series-row, .snap #toast {{ display: none !important; }}
.snap .shell {{ grid-template-columns: 1fr; }}
.snap .page {{ display: block !important; }}
.snap .main {{ padding: 20px; }}
.snap .win-card {{ break-inside: avoid; }}
.snap .win-title {{ font-size: 16px; font-weight: 700; color: var(--text); margin-bottom: 12px; font-family: var(--font-mono); }}

/* ── Window cards ── */
.win-card {{
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  margin-bottom: 20px;
}}
.win-controls {{
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
  gap: 8px;
  flex-wrap: wrap;
}}
.win-title-input {{
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 5px 10px;
  color: var(--text);
  font-family: var(--font-mono);
  font-size: 14px;
  font-weight: 600;
  outline: none;
  min-width: 160px;
  transition: border-color 0.15s;
}}
.win-title-input:focus {{ border-color: var(--accent); }}
.win-series-row {{
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: 10px;
  background: var(--surface2);
  border-radius: 6px;
  margin-bottom: 14px;
}}
.series-pill {{
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 4px 9px;
  border-radius: 4px;
  border: 1px solid var(--border);
  font-size: 11px;
  font-family: var(--font-mono);
  color: var(--muted);
  cursor: pointer;
  user-select: none;
  transition: border-color 0.15s, color 0.15s;
}}
.series-pill.on {{ border-color: var(--accent); color: var(--text); background: rgba(245,197,66,0.06); }}
.series-pill input[type=color] {{
  width: 18px; height: 14px;
  border: none; background: none;
  cursor: pointer; padding: 0;
}}
.series-pill input[type=checkbox] {{ cursor: pointer; }}

/* ── Responsive ── */
@media (max-width: 768px) {{
  .shell {{ grid-template-columns: 1fr; }}
  .sidebar {{ position: static; height: auto; }}
  .main {{ padding: 16px; }}
}}
</style>
</head>
<body>
<div class="shell">

<!-- ── SIDEBAR ─────────────────────────────────────────── -->
<nav class="sidebar">
  <div class="brand">BSS<span>/analyze</span></div>

  <div class="nav-section">Overview</div>
  <button class="nav-btn active" onclick="showPage('overview', this)">
    <div class="nav-dot"></div>Dashboard
  </button>

  <div class="nav-section">Performance</div>
  <button class="nav-btn" onclick="showPage('honey', this)">
    <div class="nav-dot"></div>Honey & Pollen
  </button>
  <button class="nav-btn" onclick="showPage('capacity', this)">
    <div class="nav-dot"></div>Capacity
  </button>
  <button class="nav-btn" onclick="showPage('balloon', this)">
    <div class="nav-dot"></div>Balloon Pollen
  </button>
  <button class="nav-btn" onclick="showPage('combined', this)">
    <div class="nav-dot"></div>Combined Graph
  </button>
  <button class="nav-btn" onclick="showPage('field', this)">
    <div class="nav-dot"></div>Field Breakdown
  </button>

  <div class="nav-section">Tiles</div>
  <button class="nav-btn" onclick="showPage('tiles', this)">
    <div class="nav-dot"></div>Tile Browser
  </button>
  <button class="nav-btn" onclick="showPage('tilegraphs', this)">
    <div class="nav-dot"></div>Tile Graphs
  </button>

  <div class="nav-section">Windows</div>
  <button class="nav-btn" onclick="showPage('windows', this)">
    <div class="nav-dot"></div>Graph Windows
  </button>

  <div style="margin-top:auto;padding-top:16px;border-top:1px solid var(--border)">
    <button class="btn primary" style="width:100%;margin-bottom:6px" onclick="saveSnapshot()">⬇ Save as HTML</button>
    <div style="font-size:10px;color:var(--muted);font-family:var(--font-mono);text-align:center;line-height:1.5">
      Renders all graphs &amp; saves<br>a clean shareable file
    </div>
  </div>
</nav>

<!-- ── MAIN ────────────────────────────────────────────── -->
<main class="main">

<!-- SESSION TABS (shown on all pages) -->
<div class="session-tabs" id="sessionTabs"></div>

<!-- ════════════ OVERVIEW ════════════ -->
<div class="page active" id="page-overview">
  <div class="page-header">
    <h1>Dashboard</h1>
    <p id="overview-sub">Session summary</p>
  </div>
  <div class="stat-grid" id="stat-grid"></div>
  <div class="chart-card">
    <div class="chart-header">
      <span class="chart-title">HONEY PER SECOND</span>
      <div class="chart-controls">
        <div class="color-pick">
          <input type="color" id="col-hps" value="#f5c542" oninput="recolorChart('hpsChart', this.value, 'HPS')">
          <span>line color</span>
        </div>
      </div>
    </div>
    <div class="chart-div" id="hpsChart"></div>
  </div>
  <div class="chart-card">
    <div class="chart-header">
      <span class="chart-title">POLLEN PER SECOND</span>
      <div class="chart-controls">
        <div class="color-pick">
          <input type="color" id="col-pps" value="#4fc3f7" oninput="recolorChart('ppsChart', this.value, 'PPS')">
          <span>line color</span>
        </div>
      </div>
    </div>
    <div class="chart-div" id="ppsChart"></div>
  </div>
</div>

<!-- ════════════ HONEY & POLLEN ════════════ -->
<div class="page" id="page-honey">
  <div class="page-header">
    <h1>Honey &amp; Pollen</h1>
    <p>Earnings over session time</p>
  </div>
  <div class="chart-card">
    <div class="chart-header">
      <span class="chart-title">TOTAL HONEY EARNED</span>
      <div class="color-pick">
        <input type="color" id="col-honey" value="#ffb74d" oninput="recolorChart('honeyChart', this.value, 'Honey')">
        <span>line color</span>
      </div>
    </div>
    <div class="chart-div" id="honeyChart"></div>
  </div>
  <div class="chart-card">
    <div class="chart-header">
      <span class="chart-title">TOTAL POLLEN COLLECTED</span>
      <div class="color-pick">
        <input type="color" id="col-pollen" value="#4fc3f7" oninput="recolorChart('pollenChart', this.value, 'Pollen')">
        <span>line color</span>
      </div>
    </div>
    <div class="chart-div" id="pollenChart"></div>
  </div>
</div>

<!-- ════════════ BALLOON ════════════ -->
<div class="page" id="page-balloon">
  <div class="page-header">
    <h1>Balloon Pollen</h1>
    <p>Pollen stored in the hive balloon — depletes during conversion</p>
  </div>
  <div class="chart-card">
    <div class="chart-header">
      <span class="chart-title">BALLOON POLLEN STORED</span>
      <div class="color-pick">
        <input type="color" id="col-balloon" value="#ce93d8" oninput="recolorChart('balloonChart', this.value, 'Balloon Pollen')">
        <span>line color</span>
      </div>
    </div>
    <div class="chart-div" id="balloonChart"></div>
  </div>
</div>

<!-- ════════════ CAPACITY ════════════ -->
<div class="page" id="page-capacity">
  <div class="page-header">
    <h1>Capacity</h1>
    <p>Field capacity over time — dips indicate conversion periods</p>
  </div>
  <div class="chart-card">
    <div class="chart-header">
      <span class="chart-title">CAPACITY</span>
      <div class="color-pick">
        <input type="color" id="col-cap" value="#81c784" oninput="recolorChart('capChart', this.value, 'Capacity')">
        <span>line color</span>
      </div>
    </div>
    <div class="chart-div" id="capChart"></div>
  </div>
</div>

<!-- ════════════ FIELD ════════════ -->
<div class="page" id="page-field">
  <div class="page-header">
    <h1>Field Breakdown</h1>
    <p>Time spent in each field</p>
  </div>
  <div class="chart-card">
    <div class="chart-header"><span class="chart-title">TIME IN FIELD</span></div>
    <div class="chart-div" id="fieldChart"></div>
  </div>
  <div class="chart-card">
    <div class="chart-header"><span class="chart-title">FIELD SHARE</span></div>
    <div class="field-list" id="fieldList"></div>
  </div>
</div>

<!-- ════════════ COMBINED GRAPH ════════════ -->
<div class="page" id="page-combined">
  <div class="page-header">
    <h1>Combined Graph</h1>
    <p>Mix any stats on one chart — toggle series, pick colors, each gets its own Y axis</p>
  </div>
  <div class="chart-card">
    <div class="chart-header">
      <span class="chart-title">SERIES</span>
      <button class="btn primary" onclick="renderCombinedGraph()">Update</button>
    </div>
    <div id="comboSeriesRow" style="display:flex;flex-wrap:wrap;gap:8px;padding:12px;background:var(--surface2);border-radius:6px;margin-bottom:16px"></div>
    <div class="chart-div" id="combinedChart"></div>
  </div>
</div>

<!-- ════════════ GRAPH WINDOWS ════════════ -->
<div class="page" id="page-windows">
  <div class="page-header">
    <h1>Graph Windows</h1>
    <p>Create multiple independent graphs — all included when you save as HTML</p>
  </div>
  <div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap">
    <button class="btn primary" onclick="addGraphWindow()">+ Add Window</button>
    <button class="btn" onclick="collapseAllWindows()">Collapse All</button>
    <button class="btn" onclick="expandAllWindows()">Expand All</button>
  </div>
  <div id="windowsContainer"></div>
</div>

<!-- ════════════ TILE BROWSER ════════════ -->
<div class="page" id="page-tiles">
  <div class="page-header">
    <h1>Tile Browser</h1>
    <p>All tiles logged this session — click to select for graphing, right-click to ignore</p>
  </div>

  <div class="ignore-panel">
    <h3>Ignored tiles</h3>
    <div class="ignore-chips" id="ignoreChips">
      <span class="empty-ignore">None ignored</span>
    </div>
  </div>

  <div class="tile-controls">
    <input class="search-box" id="tileSearch" placeholder="Search by name or ID…" oninput="filterTiles()">
    <button class="btn" onclick="clearTileSelection()">Clear selection</button>
    <button class="btn primary" onclick="graphSelected()">Graph selected →</button>
  </div>

  <div class="tile-grid" id="tileGrid"></div>
</div>

<!-- ════════════ TILE GRAPHS ════════════ -->
<div class="page" id="page-tilegraphs">
  <div class="page-header">
    <h1>Tile Graphs</h1>
    <p>Multiplier over time for selected tiles</p>
  </div>

  <div class="graph-builder">
    <h3>Graph mode</h3>
    <div class="graph-mode-row">
      <button class="mode-btn active" id="mode-combined" onclick="setGraphMode('combined', this)">Combined (all on one graph)</button>
      <button class="mode-btn" id="mode-separate" onclick="setGraphMode('separate', this)">Separate (one graph per tile)</button>
    </div>
    <button class="btn primary" onclick="renderTileGraphs()">Render graphs</button>
  </div>

  <div id="tileGraphsContainer"></div>
</div>

</main>
</div>

<div id="toast"></div>

<script>
// ─────────────────────────────────────────────────────────────────────────────
// DATA
// ─────────────────────────────────────────────────────────────────────────────
const SESSIONS = {data_json};
let activeSession = 0;
let activeLogIdx  = -1;   // -1 = combined view, 0..N = specific hour
let graphMode = 'combined';
const ignoreList  = new Set();
const tileColors  = {{}};
const selectedTiles = new Set();

function activeLog() {{
  const s = SESSIONS[activeSession];
  return activeLogIdx === -1 ? s.combined : s.hours[activeLogIdx];
}}

const PLOTLY_LAYOUT_BASE = {{
  paper_bgcolor: 'transparent',
  plot_bgcolor:  'transparent',
  font:         {{ family: 'JetBrains Mono, monospace', color: '#e8e8f0', size: 11 }},
  xaxis:        {{ gridcolor: '#2a2a38', linecolor: '#2a2a38', tickcolor: '#6b6b80', zeroline: false }},
  yaxis:        {{ gridcolor: '#2a2a38', linecolor: '#2a2a38', tickcolor: '#6b6b80', zeroline: false }},
  margin:       {{ t: 10, b: 40, l: 60, r: 20 }},
  legend:       {{ bgcolor: 'transparent', font: {{ size: 10 }} }},
  hovermode:    'x unified',
  hoverlabel:   {{ bgcolor: '#18181f', bordercolor: '#2a2a38', font: {{ family: 'JetBrains Mono', size: 11 }} }},
}};

const PLOTLY_CONFIG = {{ responsive: true, displayModeBar: false }};

// ─────────────────────────────────────────────────────────────────────────────
// UTILS
// ─────────────────────────────────────────────────────────────────────────────
function toast(msg) {{
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 2200);
}}

function fmtDuration(s) {{
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  const sec = s % 60;
  if (h > 0) return `${{h}}h ${{m}}m ${{sec}}s`;
  if (m > 0) return `${{m}}m ${{sec}}s`;
  return `${{sec}}s`;
}}

function fmtNum(n) {{
  n = Math.floor(n);
  if (n >= 1e9) return (n/1e9).toFixed(2) + 'B';
  if (n >= 1e6) return (n/1e6).toFixed(2) + 'M';
  if (n >= 1e3) return (n/1e3).toFixed(1) + 'K';
  return n.toString();
}}

function randomColor() {{
  const h = Math.floor(Math.random() * 360);
  return `hsl(${{h}}, 70%, 60%)`;
}}

function getTileColor(id) {{
  if (!tileColors[id]) tileColors[id] = randomColor();
  return tileColors[id];
}}

// ─────────────────────────────────────────────────────────────────────────────
// SESSION TABS + LOG NAVIGATOR
// ─────────────────────────────────────────────────────────────────────────────
function buildSessionTabs() {{
  const container = document.getElementById('sessionTabs');
  container.innerHTML = '';
  SESSIONS.forEach((s, i) => {{
    const btn = document.createElement('button');
    btn.className = 'sess-tab' + (i === activeSession ? ' active' : '');
    btn.textContent = s.label;
    btn.onclick = () => {{
      activeSession = i;
      activeLogIdx  = -1;
      document.querySelectorAll('.sess-tab').forEach((b, j) =>
        b.classList.toggle('active', j === i));
      buildLogNavigator();
      renderAll();
    }};
    container.appendChild(btn);
  }});
  buildLogNavigator();
}}

function buildLogNavigator() {{
  let nav = document.getElementById('logNav');
  if (!nav) {{
    nav = document.createElement('div');
    nav.id = 'logNav';
    nav.style.cssText = 'display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:20px';
    document.getElementById('sessionTabs').insertAdjacentElement('afterend', nav);
  }}

  const s = SESSIONS[activeSession];
  const hours = s.hours || [];
  const label = activeLogIdx === -1
    ? 'All Hours'
    : `Log ${{activeLogIdx + 1}} of ${{hours.length}} — ${{hours[activeLogIdx].label}}`;

  nav.innerHTML = `
    <button class="btn ${{activeLogIdx === -1 ? 'primary' : ''}}" onclick="setLogIdx(-1)">All Hours</button>
    <button class="btn" onclick="stepLog(-1)" ${{hours.length === 0 ? 'disabled' : ''}}>← Prev</button>
    <span style="font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--muted);min-width:180px;text-align:center">${{label}}</span>
    <button class="btn" onclick="stepLog(1)"  ${{hours.length === 0 ? 'disabled' : ''}}>Next →</button>
    <span style="font-size:11px;color:var(--muted);font-family:'JetBrains Mono',monospace;margin-left:4px">${{hours.length}} hour log${{hours.length !== 1 ? 's' : ''}} in session</span>
  `;
}}

function setLogIdx(idx) {{
  activeLogIdx = idx;
  buildLogNavigator();
  renderAll();
  renderActivePage();
}}

function stepLog(dir) {{
  const s = SESSIONS[activeSession];
  const hours = s.hours || [];
  if (!hours.length) return;
  if (activeLogIdx === -1) {{
    activeLogIdx = dir === 1 ? 0 : hours.length - 1;
  }} else {{
    activeLogIdx = (activeLogIdx + dir + hours.length) % hours.length;
  }}
  buildLogNavigator();
  renderAll();
  renderActivePage();
}}

// ─────────────────────────────────────────────────────────────────────────────
// NAV
// ─────────────────────────────────────────────────────────────────────────────
let activePage = 'overview';

function showPage(name, btn) {{
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  btn.classList.add('active');
  activePage = name;
  renderPageSpecific(name);
}}

function renderActivePage() {{
  renderPageSpecific(activePage);
}}

function renderPageSpecific(name) {{
  const log = activeLog();
  if (name === 'overview')   renderOverview(log);
  if (name === 'balloon')    renderBalloonPage(log);
  if (name === 'combined')   renderCombinedPage(log);
  if (name === 'windows')    renderWindowsPage();
  if (name === 'tiles')      renderTileBrowser(log);
  if (name === 'tilegraphs') renderTileGraphs();
  if (name === 'field')      renderFieldPage(log);
  if (name === 'capacity')   renderCapacityPage(log);
  if (name === 'honey')      renderHoneyPage(log);
}}

// ─────────────────────────────────────────────────────────────────────────────
// CHART HELPERS
// ─────────────────────────────────────────────────────────────────────────────
function lineTrace(x, y, name, color, fill) {{
  return {{
    x, y, name,
    type: 'scatter', mode: 'lines',
    line: {{ color, width: 2, shape: 'spline', smoothing: 0.4 }},
    fill: fill ? 'tozeroy' : 'none',
    fillcolor: fill ? hexToRgba(color, 0.07) : undefined,
    hovertemplate: `%{{y:.1f}}<extra>${{name}}</extra>`,
  }};
}}

function hexToRgba(hex, alpha) {{
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return `rgba(${{r}},${{g}},${{b}},${{alpha}})`;
}}

function recolorChart(divId, color, traceName) {{
  const el = document.getElementById(divId);
  if (!el || !el.data) return;
  const idx = el.data.findIndex(t => t.name === traceName);
  if (idx < 0) return;
  Plotly.restyle(divId, {{
    'line.color': [color],
    fillcolor: [hexToRgba(color, 0.07)],
  }}, [idx]);
}}

function addConvertingShapes(stats) {{
  const shapes = [];
  let start = null;
  stats.stats.timestamps.forEach((t, i) => {{
    const c = stats.stats.converting[i];
    if (c === true || c === 'true' || c === 'True') {{
      if (!start) start = t;
    }} else {{
      if (start) {{
        shapes.push({{
          type: 'rect', xref: 'x', yref: 'paper',
          x0: start, x1: t, y0: 0, y1: 1,
          fillcolor: 'rgba(240,98,146,0.07)',
          line: {{ width: 0 }},
        }});
        start = null;
      }}
    }}
  }});
  return shapes;
}}

// ─────────────────────────────────────────────────────────────────────────────
// HONEY PAGE
// ─────────────────────────────────────────────────────────────────────────────
function renderHoneyPage(s) {{
  const ts     = s.stats.timestamps;
  const shapes = addConvertingShapes(s);

  // Normalise honey to start from 0
  const honeyBase = s.stats.honey[0] || 0;
  const honeyRel  = s.stats.honey.map(v => v - honeyBase);

  Plotly.newPlot('honeyChart',
    [lineTrace(ts, honeyRel, 'Honey', document.getElementById('col-honey').value, true)],
    {{ ...PLOTLY_LAYOUT_BASE, height: 280, shapes,
       yaxis: {{ ...PLOTLY_LAYOUT_BASE.yaxis, title:'Honey Earned' }} }},
    PLOTLY_CONFIG);

  Plotly.newPlot('pollenChart',
    [lineTrace(ts, s.stats.pollen, 'Pollen', document.getElementById('col-pollen').value, true)],
    {{ ...PLOTLY_LAYOUT_BASE, height: 280, shapes,
       yaxis: {{ ...PLOTLY_LAYOUT_BASE.yaxis, title:'Pollen' }} }},
    PLOTLY_CONFIG);
}}

// ─────────────────────────────────────────────────────────────────────────────
// CAPACITY PAGE
