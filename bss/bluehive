const COMBO_SERIES = [
  {{ key:'hps',           label:'H/s avg',       color:'#f5c542', on:true  }},
  {{ key:'current_hps',   label:'H/s current',   color:'#ffe082', on:false }},
  {{ key:'pps',           label:'P/s avg',        color:'#4fc3f7', on:false }},
  {{ key:'current_pps',   label:'P/s current',    color:'#80deea', on:false }},
  {{ key:'honey',         label:'Total Honey',    color:'#ffb74d', on:false, normalize:true }},
  {{ key:'pollen',        label:'Pollen in Bag',  color:'#81c784', on:false }},
  {{ key:'capacity',      label:'Capacity',       color:'#ce93d8', on:false }},
  {{ key:'balloon_pollen',label:'Balloon Pollen', color:'#f06292', on:false }},
];

function buildSeriesRow(containerId, series, onUpdate) {{
  const row = document.getElementById(containerId);
  if (!row) return;
  row.innerHTML = series.map((s, i) => `
    <label class="series-pill ${{s.on ? 'on' : ''}}" id="sp-${{containerId}}-${{i}}">
      <input type="checkbox" ${{s.on ? 'checked' : ''}}
        onchange="(function(cb){{
          const s=COMBO_SERIES[${{i}}]; s.on=cb.checked;
          cb.closest('label').classList.toggle('on',cb.checked);
          ${{onUpdate}};
        }})(this)">
      <input type="color" value="${{s.color}}" onclick="event.stopPropagation()"
        oninput="COMBO_SERIES[${{i}}].color=this.value; ${{onUpdate}}">
      ${{s.label}}
    </label>`).join('');
}}

function renderCombinedPage(log) {{
  buildSeriesRow('comboSeriesRow', COMBO_SERIES, 'renderCombinedGraph()');
  renderCombinedGraph();
}}

function renderCombinedGraph() {{
  const s = activeLog();
  const ts = s.stats.timestamps;
  const shapes = addConvertingShapes(s);
  const traces = [];
  const layout = {{ ...PLOTLY_LAYOUT_BASE, height: 380, shapes }};
  let axIdx = 1;

  COMBO_SERIES.filter(sr => sr.on).forEach(sr => {{
    let data = s.stats[sr.key];
    if (!data || !data.length) return;
    if (sr.normalize) {{ const base = data[0] || 0; data = data.map(v => v - base); }}
    const ykey = axIdx === 1 ? 'y' : 'y' + axIdx;
    if (axIdx > 1) {{
      layout['yaxis' + axIdx] = {{
        ...PLOTLY_LAYOUT_BASE.yaxis,
        overlaying: 'y',
        side: axIdx % 2 === 0 ? 'right' : 'left',
        showgrid: false,
        title: sr.label,
      }};
      layout.margin = {{ t:10, b:40, l:60, r:60 }};
    }}
    traces.push({{
      x: ts, y: data, name: sr.label, type: 'scatter', mode: 'lines',
      line: {{ color: sr.color, width: 2, shape: 'spline', smoothing: 0.4 }},
      fill: axIdx === 1 ? 'tozeroy' : 'none',
      fillcolor: axIdx === 1 ? hexToRgba(sr.color, 0.06) : undefined,
      yaxis: ykey,
      hovertemplate: `%{{y:.1f}}<extra>${{sr.label}}</extra>`,
    }});
    axIdx++;
  }});

  if (!traces.length) {{
    document.getElementById('combinedChart').innerHTML =
      '<div class="empty-state" style="padding:40px"><div class="icon">📊</div>Select at least one series above.</div>';
    return;
  }}
  Plotly.newPlot('combinedChart', traces, layout, PLOTLY_CONFIG);
}}

