    sessions_data: list of { label, stats_df, tiles_df, summary, tile_summaries }
    """
    payload = []
    for sd in sessions_data:
        payload.append({
            "label":    sd["label"],
            "combined": serialize_log(sd["combined"]),
            "hours":    [serialize_log(h) for h in sd["hours"]],
        })

    data_json   = json.dumps(payload, default=str)
    colors_json = json.dumps(DEFAULT_COLORS)

