            local pct, _, txt = readBulbProgress(bulb)
            local displayName = (txt ~= "" and (txt:match("^(.-) %(") or txt:match("^(.-)%s*$"))) or "?"
            if #displayName > 24 then displayName = displayName:sub(1,22).."…" end
            local progStr = pct and string.format("%.0f%%", pct) or (txt:lower():find("ready") and "Ready" or "?")
            planterProgress[displayName] = progStr
            seen[displayName] = true
        end
        for k in pairs(planterProgress) do
            if not seen[k] then planterProgress[k] = nil end
        end
    end
end)

-- Chain spawner: watches planterChains and spawns a watcher coroutine
-- for any chain that doesn't have one yet. Uses chain.id so index
-- changes (deletions/insertions) never cause double-spawning or gaps.
task.spawn(function()
    while _G.Running do
        task.wait(1)
        for _, chain in ipairs(planterChains) do
            if not chain.id then
                chain.id = newChainId()
            end
            if not spawnedChainIds[chain.id] then
                spawnedChainIds[chain.id] = true
                task.spawn(function() watchChain(chain.id) end)
            end
        end
    end
end)

