function setGraphMode(mode, btn) {{
  graphMode = mode;
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}}

function renderTileGraphs() {{
  const container = document.getElementById('tileGraphsContainer');
  const log = activeLog();
  const tiles = (log.tile_summaries || [])
    .filter(t => selectedTiles.has(t.asset_id) && !ignoreList.has(t.asset_id));

  if (!tiles.length) {{
    container.innerHTML = '<div class="empty-state"><div class="icon">📊</div>No tiles selected.<br>Go to Tile Browser and select tiles first.</div>';
    return;
  }}

  container.innerHTML = '';

  if (graphMode === 'combined') {{
    // All tiles on a single graph
    const wrapper = document.createElement('div');
    wrapper.className = 'chart-card';
    wrapper.innerHTML = `
      <div class="chart-header">
        <span class="chart-title">TILE MULTIPLIERS — COMBINED</span>
      </div>
      <div class="tile-img-row" id="combined-imgs" style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:14px"></div>
      <div class="chart-div" id="tileGraphCombined"></div>`;
    container.appendChild(wrapper);

    // Asset images row
    const imgRow = wrapper.querySelector('#combined-imgs');
    tiles.forEach(t => {{
      const col = getTileColor(t.asset_id);
      const img = t.image
        ? `<img src="${{t.image}}" style="width:40px;height:40px;border-radius:6px;border:2px solid ${{col}};object-fit:cover">`
        : `<div style="width:40px;height:40px;border-radius:6px;border:2px solid ${{col}};background:#18181f;display:flex;align-items:center;justify-content:center;font-size:18px">🍀</div>`;
      imgRow.innerHTML += `<div style="display:flex;flex-direction:column;align-items:center;gap:4px">
        ${{img}}
        <span style="font-size:10px;color:${{col}};font-family:'JetBrains Mono',monospace;max-width:60px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${{t.name}}">${{t.name}}</span>
      </div>`;
    }});

    const traces = tiles.map(t => buildTileTrace(t));
    Plotly.newPlot('tileGraphCombined', traces,
      {{ ...PLOTLY_LAYOUT_BASE, height: 320,
         yaxis: {{ ...PLOTLY_LAYOUT_BASE.yaxis, title: 'Multiplier', tickformat: 'd' }} }},
      PLOTLY_CONFIG);

  }} else {{
    // Separate graph per tile
    tiles.forEach((t, i) => {{
      const col = getTileColor(t.asset_id);
      const img = t.image
        ? `<img src="${{t.image}}" style="width:52px;height:52px;border-radius:8px;border:2px solid ${{col}};object-fit:cover;flex-shrink:0">`
        : `<div style="width:52px;height:52px;border-radius:8px;border:2px solid ${{col}};background:#18181f;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0">🍀</div>`;

      const wrapper = document.createElement('div');
      wrapper.className = 'chart-card';
      wrapper.innerHTML = `
        <div class="chart-header">
          <div style="display:flex;align-items:center;gap:12px">
            ${{img}}
            <div>
              <div class="chart-title">${{t.name.toUpperCase()}}</div>
              <div style="font-size:11px;color:var(--muted);font-family:'JetBrains Mono',monospace;margin-top:3px">
                #${{t.asset_id}} · active ${{fmtDuration(t.total_active_s)}} · peak x${{t.peak_mult}}
              </div>
            </div>
          </div>
          <div class="color-pick">
            <input type="color" value="${{col}}"
              oninput="setTileColor('${{t.asset_id}}', this.value); renderTileGraphs()"
              title="Line color">
            <span>color</span>
          </div>
        </div>
        <div class="chart-div" id="tileGraph-${{t.asset_id}}"></div>`;
      container.appendChild(wrapper);

      Plotly.newPlot(`tileGraph-${{t.asset_id}}`, [buildTileTrace(t)],
        {{ ...PLOTLY_LAYOUT_BASE, height: 260, showlegend: false,
           yaxis: {{ ...PLOTLY_LAYOUT_BASE.yaxis, title: 'Multiplier', tickformat: 'd' }} }},
        PLOTLY_CONFIG);
    }});
  }}
}}

function buildTileTrace(t) {{
  // Build a step trace from timestamps+states+multipliers
  const x = [], y = [];
  let curMult = 0;
  t.timestamps.forEach((ts, i) => {{
    const state = t.states[i];
    const mult  = t.multipliers[i];
    x.push(ts);
    y.push(curMult);  // value just before this event
    if (state === 'Active')  curMult = mult;
    if (state === 'Removed') curMult = 0;
    x.push(ts);
    y.push(curMult);  // value just after this event
  }});
  return {{
    x, y,
    name: t.name,
    type: 'scatter',
    mode: 'lines',
    line: {{ color: getTileColor(t.asset_id), width: 2, shape: 'hv' }},
    fill: 'tozeroy',
    fillcolor: hexToRgba(getTileColor(t.asset_id), 0.1),
    hovertemplate: `x%{{y:.0f}}<extra>${{t.name}}</extra>`,
  }};
}}

