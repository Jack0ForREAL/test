def main():
    parser = argparse.ArgumentParser(description="BSS Analytics Dashboard Generator")
    parser.add_argument("--session", help='Session folder name e.g. "Session 3"')
    parser.add_argument("--all",     action="store_true", help="Merge all sessions")
    args = parser.parse_args()

    sessions = find_sessions()
    if not sessions:
        print(f"No session folders found in {LOG_ROOT}/")
        sys.exit(1)

    print(f"Found {len(sessions)} session(s): {[s.name for s in sessions]}")

    if args.all:
        targets = sessions
    elif args.session:
        match = [s for s in sessions if s.name == args.session]
        if not match:
            print(f"Session '{args.session}' not found.")
            sys.exit(1)
        targets = match
    else:
        targets = [sessions[-1]]   # default: latest
        print(f"Using latest: {targets[0].name}")

    sessions_data = []
    for path in targets:
        print(f"  Loading {path.name}…")
        combined, hour_logs = load_session(path)
        print(f"    {len(hour_logs)} hour log(s), combined stats rows: {len(combined['stats'])}")
        sessions_data.append({
            "label":    path.name,
            "combined": combined,
            "hours":    hour_logs,
        })

    print(f"Generating HTML…")
    html = build_html(sessions_data, [s["label"] for s in sessions_data])
    OUTPUT.write_text(html, encoding="utf-8")
    print(f"✅ Saved to {OUTPUT.resolve()}")
    print(f"   Open it in your browser.")


if __name__ == "__main__":
    main()
