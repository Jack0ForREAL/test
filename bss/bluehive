function renderOverview(s) {{
  const sum = s.summary;
  document.getElementById('overview-sub').textContent =
    s.label + (sum.duration_s ? ' · ' + fmtDuration(sum.duration_s) : '');

  const cards = [
    {{ label:'Total Honey', value: fmtNum(sum.honey_gained||0), sub:'earned this session', accent:'#ffb74d' }},
    {{ label:'Peak H/s',    value: fmtNum(sum.peak_hps||0),     sub:'honey per second',   accent:'#f5c542' }},
    {{ label:'Avg H/s',     value: fmtNum(sum.avg_hps||0),      sub:'average rate',       accent:'#f5c542' }},
    {{ label:'H/hour',      value: fmtNum((sum.avg_hps||0)*3600), sub:'projected',         accent:'#e5b530' }},
    {{ label:'Peak Cap',    value: fmtNum(sum.peak_capacity||0), sub:'max capacity seen',  accent:'#81c784' }},
    {{ label:'Converting',  value: (sum.converting_pct||0)+'%',  sub:'of session time',   accent:'#f06292' }},
    {{ label:'Runtime',     value: fmtDuration(sum.duration_s||0), sub:'total',           accent:'#4fc3f7' }},
  ];

  const grid = document.getElementById('stat-grid');
  grid.innerHTML = cards.map(c => `
    <div class="stat-card" style="--card-accent:${{c.accent}}">
      <div class="stat-label">${{c.label}}</div>
      <div class="stat-value">${{c.value}}</div>
      <div class="stat-sub">${{c.sub}}</div>
    </div>`).join('');

  const shapes = addConvertingShapes(s);
  const ts = s.stats.timestamps;

  // HPS: avg + current if available
  const hpsTraces = [lineTrace(ts, s.stats.hps, 'H/s avg', document.getElementById('col-hps').value, true)];
  if (s.stats.current_hps && s.stats.current_hps.some(v => v !== null))
    hpsTraces.push(lineTrace(ts, s.stats.current_hps, 'H/s current', '#ffe082', false));
  Plotly.newPlot('hpsChart', hpsTraces, {{ ...PLOTLY_LAYOUT_BASE, height: 220, shapes }}, PLOTLY_CONFIG);

  // PPS: avg + current if available
  const ppsTraces = [lineTrace(ts, s.stats.pps, 'P/s avg', document.getElementById('col-pps').value, true)];
  if (s.stats.current_pps && s.stats.current_pps.some(v => v !== null))
    ppsTraces.push(lineTrace(ts, s.stats.current_pps, 'P/s current', '#80deea', false));
  Plotly.newPlot('ppsChart', ppsTraces, {{ ...PLOTLY_LAYOUT_BASE, height: 220, shapes }}, PLOTLY_CONFIG);
}}

